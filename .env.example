# e-ravnatelj — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit real secrets.

# --- Google Gemini (server-side only) ---
# API key for the Gemini API. Used only in server route handlers.
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-flash-lite-latest).
# GEMINI_MODEL=gemini-flash-lite-latest

# --- Supabase ---
# Public project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key — SERVER-SIDE ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Sessions ---
# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=
